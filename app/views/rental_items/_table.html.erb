<div class="container-fluid mt-4">

  <div class="card shadow-sm border-0">

    <!-- HEADER -->
    <div class="card-header text-white"
         style="background-color: darkseagreen;">
      <h5 class="mb-0">Rental Items</h5>
    </div>

    <div class="card-body">

      <div class="table-responsive">
        <table class="table table-hover align-middle">

          <thead class="table-light">
            <tr>
              <th>ID</th>
              <th>Equipment</th>
              <th>Quantity</th>
              <th>Daily Price</th>
              <th>Subtotal</th>
              <th class="text-center">Actions</th>
            </tr>
          </thead>

          <tbody>
            <% if @rental.rental_items.any? %>

              <% @rental.rental_items.each do |rental_item| %>
                <tr>
                  <td><%= rental_item.equipment_id %></td>

                  <td>
                    <strong><%= rental_item.equipment&.name %></strong>
                  </td>

                  <td>
                    <span class="badge bg-secondary">
                      <%= rental_item.quantity %>
                    </span>
                  </td>

                  <td>
                    $ <%= number_with_precision(rental_item.daily_price, precision: 2) %>
                  </td>

                  <td>
                    <span class="fw-bold text-success">
                      $ <%= number_with_precision(rental_item.subtotal, precision: 2) %>
                    </span>
                  </td>

                  <td class="text-center">
                    <%= link_to "Delete",
                        [@rental, rental_item],
                        data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                        class: "btn btn-danger btn-sm shadow-sm" %>
                  </td>
                </tr>
              <% end %>

            <% else %>

              <tr>
                <td colspan="6" class="text-center text-muted py-4">
                  No rental items found.
                </td>
              </tr>

            <% end %>
          </tbody>

        </table>
      </div>

    </div>
  </div>

</div>