<div class="container-fluid mt-4">

  <div class="card shadow-sm border-0">

    <!-- HEADER -->
    <div class="card-header text-white" style="background-color: darkseagreen;">
      <h5 class="mb-0">Adicionar Item ao Aluguel</h5>
    </div>

    <div class="card-body">

      <!-- INFORMAÇÕES DO ITEM -->
      <div class="row mb-4">

        <div class="col-md-6">
          <h6 class="text-muted">Item Selecionado</h6>
          <h4 id="rental_item_name" class="fw-bold"></h4>
        </div>

        <div class="col-md-6 text-md-end">
          <strong class="text-danger" id="erro"></strong>

          <div class="mt-2">
            <span class="badge bg-secondary">
              Start: <%= @rental.start_date %>
            </span>

            <span class="badge bg-secondary">
              End: <%= @rental.end_date %>
            </span>
          </div>
        </div>

      </div>

      <hr>

      <!-- FORMULÁRIO -->
      <%= form_with(model: [@rental, @rental_item], local: true, class: "row g-4") do |form| %>

        <!-- Hidden Equipment -->
        <%= form.hidden_field :equipment_id, id: "rental_item_equipment_id" %>

        <!-- Daily Price -->
        <div class="col-md-6">
          <div class="form-floating">
            <%= form.number_field :daily_price,
              id: "rental_item_daily_price",
              step: 0.01,
              class: "form-control",
              placeholder: "Daily Price" %>
            <%= form.label :daily_price, "Preço Diário" %>
          </div>
        </div>

        <!-- Subtotal -->
        <div class="col-md-6">
          <div class="form-floating">
            <%= form.number_field :subtotal,
              id: "rental_item_subtotal",
              step: 0.01,
              readonly: true,
              class: "form-control",
              placeholder: "Subtotal" %>
            <%= form.label :subtotal, "Subtotal", id: "rental_item_subtotal" %>
          </div>
        </div>

        <!-- BOTÃO -->
        <div class="col-12">
          <%= form.submit "Create Rental Item",
              class: "btn btn-primary w-100 shadow-sm" %>
        </div>

      <% end %>

    </div>
  </div>

</div>