
<%= turbo_frame_tag "form_new_event" do %>
    <div class="card-header text-white" style="background-color: darkseagreen;">
      <h3 class="mb-3">Create New Event</h3>
    </div>

    <div class="card-body">

      <%= render "form", event: @event %>

      <hr>

      <%= link_to "← Back to events", events_path, class: "btn btn-outline-secondary" %>

    </div>
<%end%>
