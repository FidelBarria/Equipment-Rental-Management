<div class="container-fluid mt-4">

  <!-- FILTRO POR MÊS -->
  <div class="card shadow-sm mb-4">
    <div class="card-header text-white" style="background-color: darkseagreen;">
      <h5 class="mb-0 text-center">Filter by Month</h5>
    </div>

    <div class="card-body text-center">

      <div class="d-flex flex-wrap justify-content-center gap-2">

        <%= link_to "All Events", events_path, class: "btn btn-outline-success" %>

        <%= link_to "January", events_path(start_date: Date.new(Date.today.year,1,1), end_date: Date.new(Date.today.year,1,31)), class:"btn btn-outline-success" %>

        <%= link_to "February", events_path(start_date: Date.new(Date.today.year,2,1), end_date: Date.new(Date.today.year,2,28)), class:"btn btn-outline-success" %>

        <%= link_to "March", events_path(start_date: Date.new(Date.today.year,3,1), end_date: Date.new(Date.today.year,3,31)), class:"btn btn-outline-success" %>

        <%= link_to "April", events_path(start_date: Date.new(Date.today.year,4,1), end_date: Date.new(Date.today.year,4,30)), class:"btn btn-outline-success" %>

        <%= link_to "May", events_path(start_date: Date.new(Date.today.year,5,1), end_date: Date.new(Date.today.year,5,31)), class:"btn btn-outline-success" %>

        <%= link_to "June", events_path(start_date: Date.new(Date.today.year,6,1), end_date: Date.new(Date.today.year,6,30)), class:"btn btn-outline-success" %>

        <%= link_to "July", events_path(start_date: Date.new(Date.today.year,7,1), end_date: Date.new(Date.today.year,7,31)), class:"btn btn-outline-success" %>

        <%= link_to "August", events_path(start_date: Date.new(Date.today.year,8,1), end_date: Date.new(Date.today.year,8,31)), class:"btn btn-outline-success" %>

        <%= link_to "September", events_path(start_date: Date.new(Date.today.year,9,1), end_date: Date.new(Date.today.year,9,30)), class:"btn btn-outline-success" %>

        <%= link_to "October", events_path(start_date: Date.new(Date.today.year,10,1), end_date: Date.new(Date.today.year,10,31)), class:"btn btn-outline-success" %>

        <%= link_to "November", events_path(start_date: Date.new(Date.today.year,11,1), end_date: Date.new(Date.today.year,11,30)), class:"btn btn-outline-success" %>

        <%= link_to "December", events_path(start_date: Date.new(Date.today.year,12,1), end_date: Date.new(Date.today.year,12,31)), class:"btn btn-outline-success" %>

      </div>

    </div>
  </div>


  <!-- LISTA DE EVENTOS -->
  <div class="card shadow-sm">

    <div class="card-header text-white d-flex justify-content-between align-items-center" style="background-color: darkseagreen;">
      <h4 class="mb-0">Events</h4>

      <div>
        <%= render "form_pesquisa" %>
      </div>
    </div>


    <div class="card-body">

      <div class="table-responsive">

        <table class="table table-hover align-middle text-center">

          <thead class="table-light">
            <tr>
              <th>Name</th>
              <th>Start Date</th>
              <th>End Date</th>
              <th>Local</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody>

            <% @events&.each do |event| %>

            <tr>

              <td><%= event.name %></td>

              <td><%= event.start_date.strftime("%d/%m/%Y") %></td>

              <td><%= event.end_date.strftime("%d/%m/%Y") %></td>

              <td><%= event.local %></td>

              <td>

                <%= link_to "Details", event_path(event), class:"btn btn-sm btn-outline-primary" %>

                <%= link_to "Edit", edit_event_path(event), class:"btn btn-sm btn-outline-warning" %>

                <%= link_to "Add Rental",
                    new_rental_path(event_id: event.id,
                    start_date: event.start_date,
                    end_date: event.end_date),
                    class:"btn btn-sm btn-outline-success" %>

              </td>

            </tr>

            <% end %>

          </tbody>

        </table>

      </div>

    </div>

  </div>

</div>

