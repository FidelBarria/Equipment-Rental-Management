        <%= link_to "February", events_path(start_date: Date.new(Date.today.year, 2, 1), end_date: Date.new(Date.today.year, 2, 28)), class: "btn btn-primary" %>
        <%= link_to "March", events_path(start_date: Date.new(Date.today.year, 3, 1), end_date: Date.new(Date.today.year, 3, 31)), class: "btn btn-primary" %>
        <%= link_to "April", events_path(start_date: Date.new(Date.today.year, 4, 1), end_date: Date.new(Date.today.year, 4, 30)), class: "btn btn-primary" %>
        <%= link_to "May", events_path(start_date: Date.new(Date.today.year, 5, 1), end_date: Date.new(Date.today.year, 5, 31)), class: "btn btn-primary" %>
        <%= link_to "June", events_path(start_date: Date.new(Date.today.year, 6, 1), end_date: Date.new(Date.today.year, 6, 30)), class: "btn btn-primary" %>
        <%= link_to "July", events_path(start_date: Date.new(Date.today.year, 7, 1), end_date: Date.new(Date.today.year, 7, 31)), class: "btn btn-primary" %>
        <%= link_to "August", events_path(start_date: Date.new(Date.today.year, 8, 1), end_date: Date.new(Date.today.year, 8, 31)), class: "btn btn-primary" %>
        <%= link_to "September", events_path(start_date: Date.new(Date.today.year, 9, 1), end_date: Date.new(Date.today.year, 9, 30)), class: "btn btn-primary" %>
        <%= link_to "October", events_path(start_date: Date.new(Date.today.year, 10, 1), end_date: Date.new(Date.today.year, 10, 31)), class: "btn btn-primary" %>
        <%= link_to "November", events_path(start_date: Date.new(Date.today.year, 11, 1), end_date: Date.new(Date.today.year, 11, 30)), class: "btn btn-primary" %>
        <%= link_to "December", events_path(start_date: Date.new(Date.today.year, 12, 1), end_date: Date.new(Date.today.year, 12, 31)), class: "btn btn-primary" %>
        </div>
    </div>
</div>

<div class="card m-3">
    <div class="card-body d-flex justify-content-center align-items-center">
    <h1 class="text-center text-customized">Events</h1>
    </div>
    <div class="card-body d-flex justify-content-end align-items-end">
        <%= render "form_pesquisa"%>
    </div>
  <div class="card-body">
    <table class="table table-striped">
    <thead>
        <tr>
            <td scope="col" class="text-center">Name</td>
            <td scope="col" class="text-center">Start Date</td>
            <td scope="col" class="text-center">End Date</td>
            <td scope="col" class="text-center">Local</td>
            <td scope="col" class="text-center">Actions</td>
        </tr>
    </thead>  
    <tbody class="table-group-divider">
        <% @events&.each do |event|%>
        <tr>
            <td scope="row" class="text-center"><%=event.name%></td>
            <td scope="row" class="text-center"><%=event.start_date.strftime("%d/%m/%Y") %></td>
            <td scope="row" class="text-center"><%=event.end_date.strftime("%d/%m/%Y") %></td>
            <td scope="row" class="text-center"><%=event.local%></td>
            <td scope="row" class="text-center"><%= link_to "Details", event_path(event), class: "button-group" %>
                <%= link_to "Edit", edit_event_path(event), class: "button-group" %>
                <%= link_to "Add Rental", new_rental_path(event_id: event.id, start_date: event.start_date, end_date: event.end_date), class: "button-group" %>
            </td>
        </tr>
        <%end%>
    </tbody>
  </div>
</div>

