<div class="table-responsive">
  <table class="table table-striped table-hover align-middle">

    <thead style="background-color: darkseagreen; color: white;">
      <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Category</th>
        <th class="text-end">Daily Value</th>
        <th>Status</th>
        <th class="text-center">Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @equipment.each do |equipment| %>
        <tr>

          <td><%= equipment.id %></td>

          <td class="fw-semibold">
            <%= equipment.name %>
          </td>

          <td>
            <%= equipment.category&.name %>
          </td>

          <td class="text-end">
            <%= number_to_currency(equipment.daily_value) %>
          </td>

          <td>
            <span class="badge" style="background-color: darkseagreen;">
              <%= equipment.status&.humanize %>
            </span>
          </td>

          <td class="text-center">
            <%= link_to "Details", equipment,
                class: "btn btn-sm",
                style: "background-color: darkseagreen; color:white;" %>
          </td>

        </tr>
      <% end %>
    </tbody>

  </table>
</div>