<% content_for :title, "New Equipment" %>

<div class="container-fluid mt-4">

  <div class="row justify-content-center">
    <div class="col-lg-6 col-md-8 col-12">
<%= turbo_frame_tag "form_new_equipment" do %>
      <div class="card shadow-sm">

        <div class="card-header text-center">
          <h2 class="text-customized">New Equipment</h2>
        </div>

        <div class="card-body">
          <%= render "form", equipment: @equipment %>
        </div>

        <div class="card-footer text-center">
          <%= link_to "Back to Equipment", equipment_index_path, class: "btn btn-secondary" %>
        </div>

      </div>
<%end%>
    </div>
  </div>

</div>
