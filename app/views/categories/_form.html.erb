<div class="container-fluid mt-4">

  <div class="row justify-content-center">

    <div class="col-lg-6">

      <div class="card shadow-sm">

        <div class="card-header text-white"
             style="background-color: darkseagreen;">

          <h4 class="mb-0">Category Form</h4>

        </div>

        <div class="card-body">

          <%= form_with model: category do |form| %>

            <% if category.errors.any? %>
              <div class="alert alert-danger">
                <h5>
                  <%= pluralize(category.errors.count, "error") %> prevented this category from being saved
                </h5>
                <ul>
                  <% category.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="mb-3">
              <%= form.label :name, class: "form-label fw-semibold" %>
              <%= form.text_field :name, class: "form-control" %>
            </div>

            <div class="mb-3">
              <%= form.label :description, class: "form-label fw-semibold" %>
              <%= form.text_field :description, class: "form-control" %>
            </div>

            <div class="d-flex justify-content-between">

              <%= link_to "Back",
                  categories_path,
                  class: "btn btn-outline-secondary" %>

              <%= form.submit "Save Category",
                  class: "btn text-white",
                  style: "background-color: darkseagreen;" %>

            </div>

          <% end %>

        </div>

      </div>

    </div>

  </div>

</div>