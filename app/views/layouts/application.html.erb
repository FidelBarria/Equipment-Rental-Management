<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Equipment Rental Management" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Equipment Rental Management">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%# javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

  </head>

  <body data-turbo="false">
  <% if logged_in? %>
  <div class="container-header">
    <h3>Empresa de Eventos</h3>
    <div class="header-usuario">
      <p><strong><%= current_user.name%></strong></p>
        <p>Operador</p>
    </div>
  </div>
    <br/>
    <br/>
    <br/>
    <br/>
  <div class="menu_top">
      <div class="dropdown"> 
        <button class="btn btn-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">Rentals</button>
          <ul class="dropdown-menu" style="background-color: darkseagreen">
            <li><%= link_to "Manage Rentals", rentals_path, class: "dropdown-item text-white" %></li>
          </ul>
      </div>
      <div class="dropdown">
        <button class="btn btn-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">Events</button>
          <ul class="dropdown-menu" style="background-color: darkseagreen">
            <li><%= link_to "New Events", new_event_path, class: "dropdown-item text-white" %></li>
            <li><%= link_to "Manage Events", events_path, class: "dropdown-item text-white" %></li>
          </ul>
      </div>
      <div class="dropdown">
        <button class="btn btn-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">Registration</button>
          <ul class="dropdown-menu" style="background-color: darkseagreen">
            <li><%= link_to "Clients", clients_path, class: "dropdown-item text-white" %></li>
            <li><%= link_to "Users", users_path, class: "dropdown-item text-white" %></li>
            <li><%= link_to "Equipments", equipment_index_path, class: "dropdown-item text-white" %></li>
            <li><%= link_to "Categories", categories_path, class: "dropdown-item text-white" %></li>
          </ul>
      </div>
      <div>
        <% if logged_in? %>
          <%= button_to "Sair", logout_path, method: :delete, class: "btn btn-primary" %>
        <% end %>
      </div>
  </div>
  <%end%>
  
    <%= yield %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
  </body>
</html>
