<%= form_with model: @client, local: true do |form| %>

  <div class="row g-3">

    <div class="col-md-6">
      <%= form.label :name, class: "form-label fw-bold" %>
      <%= form.text_field :name, class: "form-control" %>
    </div>

    <div class="col-md-6">
      <%= form.label :cpf_cnpj, class: "form-label fw-bold" %>
      <%= form.text_field :cpf_cnpj, class: "form-control" %>
    </div>

    <div class="col-md-6">
      <%= form.label :email, class: "form-label fw-bold" %>
      <%= form.email_field :email, class: "form-control" %>
    </div>

    <div class="col-md-6">
      <%= form.label :phone, class: "form-label fw-bold" %>
      <%= form.text_field :phone, class: "form-control" %>
    </div>

    <div class="col-12">
      <%= form.label :adress, class: "form-label fw-bold" %>
      <%= form.text_field :adress, class: "form-control" %>
    </div>

  </div>

  <div class="d-flex justify-content-center mt-4">
    <%= form.submit "Save Client", class: "btn btn-primary px-4" %>
  </div>

<% end %>